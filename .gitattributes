# Force LF in the repo for all text. Git checks out with the platform's
# native line endings only if you also set core.autocrlf — but with
# `text=auto eol=lf` set here, every text blob normalizes to LF on commit
# regardless of platform, so Win + macOS stay byte-equal in git.
* text=auto eol=lf

# Godot text formats — explicit so editors don't guess.
*.tscn        text eol=lf
*.tres        text eol=lf
*.gd          text eol=lf
*.gdshader    text eol=lf
*.import      text eol=lf
*.uid         text eol=lf
*.godot       text eol=lf
project.godot text eol=lf

# Scripts
*.py text eol=lf
*.sh text eol=lf
*.ps1 text eol=crlf

# Markdown / json / config
*.md   text eol=lf
*.json text eol=lf
*.toml text eol=lf
*.cfg  text eol=lf

# Binary — never normalize, never diff as text.
*.glb   binary
*.gltf  binary
*.png   binary
*.jpg   binary
*.jpeg  binary
*.webp  binary
*.ico   binary
*.bmp   binary
*.tga   binary
*.exr   binary
*.hdr   binary
*.ogg   binary
*.wav   binary
*.mp3   binary
*.ttf   binary
*.otf   binary
*.zip   binary
*.exe   binary
*.dll   binary
*.dylib binary
*.so    binary
*.pck   binary
