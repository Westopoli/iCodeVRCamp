# Godot import cache (machine-specific, regenerated on first open).
# NOTE: `.import` files ARE tracked — they hold stable UIDs that .tscn
# files reference. Excluding them breaks asset references on a fresh clone.
# Only the regenerated .godot/imported/ cache is excluded.
.godot/

# Build-script staging
.tmp/

# Smoke-test logs (ephemeral)
_stderr.log
_stdout.log
_*.log

# Ephemeral build specs (delete after build, but exclude if missed)
_BUILD_SPEC.md

# Swarm cascade state (briefs, assumptions, leaf workspaces)
.swarm/

# Python bytecode (sim/balance scripts)
__pycache__/
*.pyc
.pytest_cache/

# OS junk
.DS_Store
Thumbs.db
desktop.ini

# Editor
.vscode/
.idea/
