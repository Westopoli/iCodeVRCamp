_BUILD_SPEC.md

# Swarm cascade state (briefs, assumptions, leaf workspaces)
.swarm/

# Python bytecode (sim/balance scripts)
__pycache__/
*.pyc
.pytest_cache/

# OS junk
.DS_Store
Thumbs.db
desktop.ini

# Editor
.vscode/
.idea/
